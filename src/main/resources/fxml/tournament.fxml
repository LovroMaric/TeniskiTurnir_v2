<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.TournamentController">

    <top>
        <VBox spacing="10" style="-fx-padding: 10;">

            <Label text="Tournament CRUD" style="-fx-font-size: 18px;"/>

            <GridPane hgap="10" vgap="10">

                <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Year:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="yearField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Prize:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="prizeField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Surface:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <ComboBox fx:id="surfaceBox" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Image Path:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="imagePathField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Country:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <ComboBox fx:id="countryBox" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <Label text="Category:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <ComboBox fx:id="categoryBox" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                <ImageView fx:id="tournamentImageView"
                           fitWidth="220"
                           fitHeight="160"
                           preserveRatio="true"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="2"
                           GridPane.rowSpan="7"/>

            </GridPane>

            <HBox spacing="10">
                <Button text="Add" onAction="#add"/>
                <Button text="Update" onAction="#update"/>
                <Button text="Delete" onAction="#delete"/>
                <Button text="Export XML" onAction="#exportXml"/>
            </HBox>

        </VBox>
    </top>

    <center>
        <HBox spacing="15" style="-fx-padding: 10;">

            <VBox spacing="5">
                <Label text="Players (Drag from here)"/>

                <TableView fx:id="playerTable" prefWidth="300">
                    <columns>
                        <TableColumn fx:id="playerIdCol" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="playerNameCol" text="Name" prefWidth="120"/>
                        <TableColumn fx:id="rankingCol" text="Rank" prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="5">
                <Label text="Tournaments (Drop here)"/>

                <TableView fx:id="tournamentTable" prefWidth="700">
                    <columns>
                        <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="nameCol" text="Name" prefWidth="150"/>
                        <TableColumn fx:id="yearCol" text="Year" prefWidth="80"/>
                        <TableColumn fx:id="prizeCol" text="Prize" prefWidth="120"/>
                        <TableColumn fx:id="surfaceCol" text="Surface" prefWidth="100"/>
                        <TableColumn fx:id="countryCol" text="Country" prefWidth="120"/>
                        <TableColumn fx:id="categoryCol" text="Category" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

        </HBox>
    </center>

</BorderPane>